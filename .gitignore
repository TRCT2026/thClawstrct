# =========================
# thClaws .gitignore
# =========================

# --- Secrets / Credentials (CRITICAL) ---
*.env
.env.*
*.key
*.pem
*.pfx
secrets.json
credentials.json
api_keys.txt
config.local.*

# --- Temp / Scratch ---
_temp/
_logs/
*.tmp
*.bak
*.swp
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ipynb_checkpoints/

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
.next/
dist/
build/

# --- IDE ---
.vscode/
.idea/
*.iml

# --- Trading: Large data / Private results ---
02-trading/data/*.csv
02-trading/data/*.parquet
02-trading/backtests/*_private.*
02-trading/bots/live_*.json

# --- Government: Sensitive drafts ---
03-government/**/*_DRAFT.*
03-government/**/*_CONFIDENTIAL.*

# --- Office lock files ---
~$*.docx
~$*.xlsx
~$*.pptx

# --- Archive (optional - uncomment to exclude) ---
# 99-shared/archive/
